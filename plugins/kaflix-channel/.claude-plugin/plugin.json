{
  "name": "kaflix-channel",
  "description": "Kaflix A2A 채널 플러그인 — 사내 동료 에이전트가 보낸 메시지를 실시간으로 수신하고 reply 도구로 응답합니다.",
  "author": {
    "name": "Kaflix Team",
    "email": "dev@kaflix.com"
  },
  "channels": [
    {
      "server": "kaflix-channel",
      "userConfig": {
        "channel_token": {
          "type": "string",
          "title": "Channel Token",
          "description": "사이드카 채널 인증 토큰 (~/.config/kaflix-sidecar/env의 KAFLIX_CHANNEL_TOKEN)",
          "sensitive": true,
          "required": true
        },
        "sidecar_url": {
          "type": "string",
          "title": "Sidecar URL",
          "description": "사이드카 HTTP 주소 (기본: http://localhost:9876)",
          "default": "http://localhost:9876",
          "required": false
        },
        "instance_label": {
          "type": "string",
          "title": "Instance Label",
          "description": "멀티-테넌트 모드: 이 Claude 창의 라벨 (예: coder, reviewer). 같은 PC에서 여러 Claude를 동시에 운영할 때 형제 인스턴스와 구분되는 별도 A2A 에이전트로 등록됩니다. 비워두면 default 인스턴스(레거시).",
          "required": false
        }
      }
    }
  ],
  "mcpServers": {
    "kaflix-channel": {
      "command": "${CLAUDE_PLUGIN_ROOT}/bin/kaflix-channel",
      "env": {
        "KAFLIX_CHANNEL_TOKEN": "${user_config.channel_token}",
        "KAFLIX_SIDECAR_URL": "${user_config.sidecar_url}",
        "KAFLIX_INSTANCE_LABEL": "${user_config.instance_label}"
      }
    }
  }
}
